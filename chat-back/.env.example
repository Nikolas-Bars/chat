# Скопируй в файл .env в этой же папке ( .env в git не коммитится )
# Те же параметры вставь в Render → Environment

# Railway MySQL (для yarn migration:run:prod с твоей машины)
# DB_HOST=
# DB_PORT=18822
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=railway
# DB_SSL=true

# Продакшен на Render: Gmail SMTP часто не работает (таймаут) — используй Resend (HTTPS):
# RESEND_API_KEY=re_...
# RESEND_FROM=onboarding@resend.dev
# или свой домен после верификации в Resend

# Локально / где SMTP не блокируют:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USER=docum.magic0@gmail.com
SMTP_PASS=
SMTP_FROM="Nikolas Bars" <docum.magic0@gmail.com>
# Дополнительно (опционально) для нестабильных сетей:
# SMTP_CONNECTION_TIMEOUT_MS=12000
# SMTP_GREETING_TIMEOUT_MS=12000
# SMTP_SOCKET_TIMEOUT_MS=20000
